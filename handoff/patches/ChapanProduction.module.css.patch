--- a/src/pages/workzone/chapan/production/ChapanProduction.module.css
+++ b/src/pages/workzone/chapan/production/ChapanProduction.module.css

@@ .tableHeader — убрать border-top и inset shadow @@

 .tableHeader {
   position: sticky;
   top: var(--workshop-header-offset);
   z-index: 18;
   display: grid;
   grid-template-columns: var(--workshop-columns);
   align-items: center;
   min-height: 54px;
   padding: 0 24px 0 20px;
   background:
     linear-gradient(
       90deg,
       color-mix(in srgb, var(--ch-accent) 74%, white 26%) 0%,
       var(--ch-accent) 100%
     );
-  border-top: 1px solid color-mix(in srgb, white 18%, transparent);
   border-bottom: 1px solid color-mix(in srgb, var(--ch-accent) 42%, var(--ch-border));
-  box-shadow: inset 0 1px 0 color-mix(in srgb, white 16%, transparent);
   color: var(--text-on-accent, #fff);
 }

@@ .cardList — уменьшить gap, убрать overflow-x @@

 .cardList {
   display: flex;
   flex-direction: column;
-  gap: 12px;
+  gap: 4px;
   padding: 18px 24px 28px 20px;
 }

@@ .card — уменьшить border-radius @@

 .card {
   display: grid;
   grid-template-columns: var(--workshop-columns);
   grid-auto-rows: minmax(68px, auto);
   align-items: stretch;
   border: 1px solid color-mix(in srgb, var(--ch-accent) 10%, var(--ch-border));
   border-left: 3px solid color-mix(in srgb, var(--ch-accent) 12%, var(--ch-border));
-  border-radius: 22px;
+  border-radius: 10px;
   background: color-mix(in srgb, var(--ch-card) 96%, white 4%);
   box-shadow: var(--shadow-xs);
   overflow: hidden;
   transition: border-color 140ms ease, box-shadow 140ms ease, background 140ms ease;
 }

@@ .doneBtn — убрать pill-radius @@

 .doneBtn {
   display: inline-flex;
   align-items: center;
   justify-content: center;
   gap: 6px;
   flex: 1 1 auto;
   width: 100%;
   min-height: 42px;
   min-width: 132px;
   padding: 0 18px;
-  border-radius: 999px;
+  border-radius: 10px;
   border: 1px solid color-mix(in srgb, var(--fill-positive) 26%, var(--ch-border));
   background: color-mix(in srgb, var(--fill-positive-soft) 84%, var(--ch-card));
   color: var(--fill-positive, #10b981);
   font-size: 12px;
   font-weight: 700;
   font-family: inherit;
   cursor: pointer;
   transition: background 140ms ease, border-color 140ms ease, transform 140ms ease;
 }

@@ новый класс — общий scroll-wrapper для header + cardList @@

+.tableScrollWrap {
+  overflow-x: auto;
+  -webkit-overflow-scrolling: touch;
+}

@@ @media (max-width: 1080px) — убрать overflow-x из cardList @@

 @media (max-width: 1080px) {
   .controls {
     min-width: 0;
     flex-wrap: wrap;
   }

   .searchInput {
     max-width: none;
     min-width: min(100%, 280px);
   }

   .cardList {
-    overflow-x: auto;
-    padding-bottom: 18px;
   }

   .tableHeader,
   .card {
     min-width: 1030px;
   }
 }
