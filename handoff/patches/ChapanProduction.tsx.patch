@@ ВАЖНО: position: sticky в tableHeader @@

  CSS-ограничение: position: sticky не работает внутри overflow-x: auto контейнера.
  После этого изменения tableHeader перестанет быть sticky по вертикали.

  Варианты решения (на выбор команды):

  Вариант A — убрать sticky (проще всего, рекомендуется):
    В ChapanProduction.module.css у .tableHeader удалить:
      position: sticky;
      top: var(--workshop-header-offset);
      z-index: 18;

  Вариант B — sticky через JS-синхронизацию скролла:
    Оставить tableHeader вне scrollWrap, добавить ref на оба контейнера
    и синхронизировать scrollLeft через onScroll handler:

      const headerRef = useRef<HTMLDivElement>(null);
      const listRef   = useRef<HTMLDivElement>(null);

      const syncScroll = (source: 'header' | 'list') => (e: React.UIEvent) => {
        const scrollLeft = (e.target as HTMLElement).scrollLeft;
        if (source === 'list'   && headerRef.current) headerRef.current.scrollLeft = scrollLeft;
        if (source === 'header' && listRef.current)   listRef.current.scrollLeft   = scrollLeft;
      };

      // JSX:
      <div ref={headerRef} className={styles.tableHeader}
           style={{overflowX:'hidden'}} onScroll={syncScroll('header')} />
      <div ref={listRef}   className={styles.cardList}
           style={{overflowX:'auto'}}   onScroll={syncScroll('list')} />
