# ──────────────────────────────────────────────────────────────
#  KORT Backend — Environment Variables
# ──────────────────────────────────────────────────────────────

# PostgreSQL connection string
DATABASE_URL="postgresql://kort:kort_secret@localhost:5432/kort_db"

# JWT secrets — CHANGE IN PRODUCTION (min 32 chars recommended)
JWT_ACCESS_SECRET="kort-access-secret-dev-only-change-me"
JWT_REFRESH_SECRET="kort-refresh-secret-dev-only-change-me"

# Token lifetimes
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"

# Server
PORT=8000
HOST="0.0.0.0"

# Frontend origin for CORS
CORS_ORIGIN="http://localhost:5173"

# Dev console password (used by service.routes.ts in non-production only)
CONSOLE_SERVICE_PASSWORD="kortdev1234"

# ── Sprint 10-11: Google Sheets integration (optional, API Key method) ─────────
# 1. Create a Google Cloud project and enable Google Sheets API
# 2. Create an API Key in Google Cloud Console → APIs & Services → Credentials
# 3. Restrict API Key to Google Sheets API only
# 4. Create a Google Sheet and share it
# 5. Run: pnpm install googleapis
# 6. Set the env vars below (already uncommented code in sheets.sync.ts)

GOOGLE_SHEETS_SPREADSHEET_ID="your-spreadsheet-id-here"
GOOGLE_SHEETS_SHEET_NAME="Orders"
# Service Account auth (API Key does NOT support writes — use Service Account)
# 1. Create a Service Account in Google Cloud Console
# 2. Share the spreadsheet with the service account email (Editor)
# 3. Download the JSON key, copy email and private_key from it
GOOGLE_SERVICE_ACCOUNT_EMAIL="your-service-account@project.iam.gserviceaccount.com"
# Private key: paste raw (with \n) or base64-encode the entire PEM block
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# ── Cloudflare R2 (optional at startup; required for file uploads / attachments) ──
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET="your-r2-bucket-name"
