}

model WarehouseOutbox {
  id              String    @id @default(cuid())
  orgId           String    @map("org_id")
  warehouseSiteId String?   @map("warehouse_site_id")
  aggregateType   String    @map("aggregate_type")
  aggregateId     String    @map("aggregate_id")
  eventType       String    @map("event_type")
  payload         Json
  status          String    @default("pending")
  availableAt     DateTime  @default(now()) @map("available_at")
  processedAt     DateTime? @map("processed_at")
  retryCount      Int       @default(0) @map("retry_count")
  lastError       String?   @map("last_error")
  createdAt       DateTime  @default(now()) @map("created_at")

  org  Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  site WarehouseSite? @relation(fields: [warehouseSiteId], references: [id], onDelete: SetNull)

  @@index([orgId, status, availableAt])
  @@index([orgId, aggregateType, aggregateId])
  @@map("warehouse_outbox")
}

model WarehouseProjectionInbox {
  id              String    @id @default(cuid())
  orgId           String    @map("org_id")
  warehouseSiteId String?   @map("warehouse_site_id")
  consumer        String
  eventId         String    @map("event_id")
  status          String    @default("processed")
  payloadHash     String?   @map("payload_hash")
  processedAt     DateTime  @default(now()) @map("processed_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  org  Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  site WarehouseSite? @relation(fields: [warehouseSiteId], references: [id], onDelete: SetNull)

  @@unique([orgId, consumer, eventId])
  @@index([orgId, consumer, processedAt])
  @@map("warehouse_projection_inbox")
}

model WarehouseLayoutPublishAudit {
  id                  String    @id @default(cuid())
  orgId               String    @map("org_id")
  warehouseSiteId     String    @map("warehouse_site_id")
  layoutVersionId     String    @map("layout_version_id")
  action              String    // publish | force_publish | rollback
  actorName           String    @map("actor_name")
  forceReason         String?   @map("force_reason")
  previousVersionId   String?   @map("previous_version_id")
  blockerSummaryJson  Json?     @map("blocker_summary_json")
  impactedTaskCount   Int       @default(0) @map("impacted_task_count")
  createdAt           DateTime  @default(now()) @map("created_at")

  org  Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  site WarehouseSite @relation(fields: [warehouseSiteId], references: [id], onDelete: Cascade)

  @@index([orgId, warehouseSiteId, createdAt(sort: Desc)])
  @@index([layoutVersionId])
  @@map("warehouse_layout_publish_audit")
}

model Conversation {
  id        String   @id @default(cuid())
  orgId     String   @map("org_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  org          Organization              @relation(fields: [orgId], references: [id], onDelete: Cascade)
  participants ConversationParticipant[]
  messages     Message[]

  @@index([orgId])
  @@map("conversations")
}

model ConversationParticipant {
  id             String    @id @default(cuid())
  conversationId String    @map("conversation_id")
  userId         String    @map("user_id")
  unreadCount    Int       @default(0) @map("unread_count")
  lastReadAt     DateTime? @map("last_read_at")
  joinedAt       DateTime  @default(now()) @map("joined_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
  @@map("conversation_participants")
}

enum MessageType {
  TEXT
  IMAGE
  FILE
  ORDER_REF
}

model Message {
  id             String      @id @default(cuid())
  conversationId String      @map("conversation_id")
  senderId       String      @map("sender_id")
  body           String      @db.Text
  type           MessageType @default(TEXT)
  replyToId      String?     @map("reply_to_id")
  editedAt       DateTime?   @map("edited_at")
  deletedAt      DateTime?   @map("deleted_at")
  orderId        String?     @map("order_id")
  createdAt      DateTime    @default(now()) @map("created_at")
  readAt         DateTime?   @map("read_at")

  conversation Conversation    @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User            @relation(fields: [senderId], references: [id])
  replyTo      Message?        @relation("MessageReplies", fields: [replyToId], references: [id])
  replies      Message[]       @relation("MessageReplies")
  attachments  ChatAttachment[]

  @@index([conversationId, createdAt])
  @@map("messages")
}

model ChatAttachment {
  id          String   @id @default(cuid())
  messageId   String   @map("message_id")
  orgId       String   @map("org_id")
  fileName    String   @map("file_name")
  mimeType    String   @map("mime_type")
  sizeBytes   Int      @map("size_bytes")
  storagePath String   @map("storage_path")
  width       Int?
  height      Int?
  createdAt   DateTime @default(now()) @map("created_at")

  message Message      @relation(fields: [messageId], references: [id], onDelete: Cascade)
  org     Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@map("chat_attachments")
}
