# Test Environment Variables
NODE_ENV="test"

# Database (use test database)
DATABASE_URL="postgresql://kort:kort_secret@localhost:5432/kort_db_test"

# JWT (test secrets)
JWT_ACCESS_SECRET="test-secret-access-32-chars-minimum"
JWT_REFRESH_SECRET="test-secret-refresh-32-chars-minimum"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"

# Server
PORT=8000
HOST="0.0.0.0"

# CORS
CORS_ORIGIN="http://localhost:5173,http://localhost:3000"

# Console
CONSOLE_SERVICE_PASSWORD="test1234"

# Google Sheets (optional for tests)
# GOOGLE_SHEETS_SPREADSHEET_ID="test-id"
# GOOGLE_SHEETS_SHEET_NAME="Orders"
# GOOGLE_SHEETS_API_KEY="test-key"
